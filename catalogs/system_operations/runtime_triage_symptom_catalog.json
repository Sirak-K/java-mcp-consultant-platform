      "signals": [
        {
          "signal_key": "tool_rejections_total",
          "signal_source": "metrics",
          "detail_template": "count={count}"
        },
        {
          "signal_key": "global_concurrency_available_permits_low",
          "signal_source": "runtime",
          "detail_template": "available={available}, max={max}"
        }
      ]
    },
    {
      "symptom_key": "tool_queue_pressure_observed",
      "operator_hint": "Kontrollera koevantan, belastningstoppar och om samtidighetsgranser behover justeras.",
