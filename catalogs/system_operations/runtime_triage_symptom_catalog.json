        {
          "signal_key": "transport_error_count",
          "signal_source": "runtime",
          "detail_template": "count={count}"
        },
        {
          "signal_key": "transport_errors_total",
          "signal_source": "metrics",
          "detail_template": "count={count}"
        },
        {
          "signal_key": "test_log_available",
          "signal_source": "logging",
          "detail_template": "enabled={enabled}, required={required}, exists={exists}"
        },
        {
          "signal_key": "error_log_available",
          "signal_source": "logging",
          "detail_template": "enabled={enabled}, required={required}, exists={exists}"
        }
      ]
    },
    {
      "symptom_key": "auth_denials_observed",
