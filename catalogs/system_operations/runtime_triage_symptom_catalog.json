          "signal_key": "tool_queue_wait_max_millis",
          "signal_source": "metrics",
          "detail_template": "maxMillis={maxMillis}"
        },
        {
          "signal_key": "tool_queue_wait_p95_millis",
          "signal_source": "metrics",
          "detail_template": "p95Millis={p95Millis}"
        },
        {
          "signal_key": "tool_queue_wait_p99_millis",
          "signal_source": "metrics",
          "detail_template": "p99Millis={p99Millis}"
        }
      ]
    },
    {
      "symptom_key": "persistence_failures_observed",
      "operator_hint": "Kontrollera databasfel, pooltryck och traces kring persistenslagret.",
      "signals": [
