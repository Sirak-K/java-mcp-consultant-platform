        {
          "signal_key": "server_log_missing",
          "signal_source": "runtime",
          "detail_template": "required={required}, exists={exists}"
        },
        {
          "signal_key": "error_log_missing",
          "signal_source": "runtime",
          "detail_template": "required={required}, exists={exists}"
        },
        {
          "signal_key": "audit_log_missing",
          "signal_source": "runtime",
          "detail_template": "required={required}, exists={exists}"
        },
        {
          "signal_key": "test_log_missing",
          "signal_source": "runtime",
          "detail_template": "required={required}, exists={exists}"
        },
        {
          "signal_key": "canonical_logs_present_failed",
          "signal_source": "checks",
          "detail_template": "{detail}"
        }
      ]
    },
    {
      "symptom_key": "tool_timeouts_observed",
