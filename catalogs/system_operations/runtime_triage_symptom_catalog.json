{
  "catalog_id": "runtime_triage_symptom_catalog",
  "runtime_triage_catalog_version": "1.0",
  "runtime_triage_symptoms": [
    {
      "symptom_key": "readiness_down",
      "operator_hint": "Kontrollera /ops/health/ready och identifiera vilken dependency som ar DOWN.",
      "signals": [
        {
          "signal_key": "ready_status_down",
          "signal_source": "health",
          "detail_template": "status={status}"
        },
        {
          "signal_key": "runtime_check_down",
          "signal_source": "health",
          "detail_template": "{detail}"
        },
        {
          "signal_key": "database_check_down",
          "signal_source": "health",
          "detail_template": "{detail}"
        }
      ]
    },
    {
      "symptom_key": "database_unreachable",
      "operator_hint": "Kontrollera databasanslutning och readiness-checkens database-signal.",
      "signals": [
        {
          "signal_key": "database_down",
          "signal_source": "health",
          "detail_template": "{detail}"
        },
        {
          "signal_key": "database_reachable_failed",
          "signal_source": "checks",
          "detail_template": "{detail}"
        }
      ]
    },
    {
      "symptom_key": "transport_errors_observed",
      "operator_hint": "Kontrollera error-loggen och transportspecifika fel kring natverk eller SSE/WebSocket-leverans.",
