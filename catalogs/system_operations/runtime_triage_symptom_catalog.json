      "signals": [
        {
          "signal_key": "status",
          "signal_source": "calibration",
          "detail_template": "{status}"
        },
        {
          "signal_key": "recommendations_present",
          "signal_source": "calibration",
          "detail_template": "count={count}"
        },
        {
          "signal_key": "tool_queue_wait_p95_millis",
