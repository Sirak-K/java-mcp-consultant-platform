# java-mcp-consultant-platform
# Copy this file to .env for local development and replace placeholder values.
# Optional: create .env.local for machine-local overrides; start_dev.sh loads it after .env.


# Spring profile
SPRING_PROFILES_ACTIVE=dev

# Backend HTTP
SERVER_PORT=8080

# Local PostgreSQL development database
MCP_DB_DEV_URL=jdbc:postgresql://localhost:5432/db_mcp
MCP_DB_DEV_USERNAME=postgres
MCP_DB_DEV_PASSWORD=replace_with_local_postgres_password

# Local operator-only development authentication
MCP_APP_DEV_AUTH_ALLOWED_ORIGIN=http://localhost:5173
MCP_APP_DEV_AUTH_OPS_EMAIL=ops@example.test
MCP_APP_DEV_AUTH_OPS_PASSWORD=replace_with_local_ops_password
MCP_APP_DEV_AUTH_OPS_BYPASS_ENABLED=true

# Local runtime mode
MCP_CONTROL_PLANE_ENABLED=true
MCP_CUSTOMER_DATA_MODE=postgresql
MCP_TRANSPORT_ACTIVE=streamable-http
MCP_SECURITY_NETWORK_AUTH_ENABLED=false

# Local AI generation runtime
MCP_AI_GENERATION_MCP_ENDPOINT_URL=http://127.0.0.1:8080/mcp
MCP_AI_GENERATION_MCP_TRANSPORT_KIND=streamable_http
MCP_AI_GENERATION_MCP_TIMEOUT_SECONDS=30.0
MCP_AI_GENERATION_RUNTIME_BASE_URL=http://127.0.0.1:8091
MCP_AI_GENERATION_RUNTIME_RUN_PATH=/candidate-presentation-generation/runs
MCP_AI_GENERATION_RUNTIME_CONNECT_TIMEOUT_MILLIS=1000
MCP_AI_GENERATION_RUNTIME_REQUEST_TIMEOUT_MILLIS=5000

# Local match notification email delivery
MATCH_NOTIFICATION_REAL_SEND_ENABLED=false
MATCH_NOTIFICATION_BREVO_API_KEY=replace_with_local_brevo_api_key
MATCH_NOTIFICATION_BREVO_SENDER_EMAIL=replace_with_verified_sender_email
MATCH_NOTIFICATION_BREVO_SENDER_NAME=Consultant Match Ops
MATCH_NOTIFICATION_BREVO_REPLY_TO_EMAIL=
MATCH_NOTIFICATION_BREVO_REPLY_TO_NAME=
MATCH_NOTIFICATION_OPS_RECIPIENT_EMAIL=platform-ops@example.com
MATCH_NOTIFICATION_OPS_RECIPIENT_NAME=Platform Operator
MATCH_NOTIFICATION_MOCK_SENDER_EMAIL=match-notifications@local.test

# Local Keycloak development container
KEYCLOAK_PORT=8090
KC_BOOTSTRAP_ADMIN_USERNAME=dev_admin
KC_BOOTSTRAP_ADMIN_PASSWORD=replace_with_local_keycloak_admin_password

# Frontend development proxy
VITE_BACKEND_PROXY_TARGET=http://localhost:8080
